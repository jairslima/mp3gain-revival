<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MP3GainUI.AboutWindow"
        Title="Sobre o MP3Gain Revival"
        Width="520" Height="320"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Border Padding="16">
    <StackPanel Spacing="10">
      <TextBlock Text="MP3Gain Revival" FontSize="22" FontWeight="Bold"/>
      <TextBlock Text="Interface gráfica unificada para o CLI do MP3Gain Revival." TextWrapping="Wrap"/>

      <Grid ColumnDefinitions="170,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Versão:" FontWeight="Bold"/>
        <TextBlock Grid.Row="0" Grid.Column="1" Name="TxtVersion" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Referência ReplayGain:" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" Grid.Column="1" Name="TxtReference" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Executável CLI:" FontWeight="Bold"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Name="TxtCliPath" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Executável GUI:" FontWeight="Bold"/>
        <TextBlock Grid.Row="3" Grid.Column="1" Name="TxtGuiPath" TextWrapping="Wrap"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Licença:" FontWeight="Bold"/>
        <TextBlock Grid.Row="4" Grid.Column="1" Text="LGPL 2.1 ou posterior" TextWrapping="Wrap"/>
      </Grid>

      <TextBlock
          Text="Status: build Windows unificado com GUI + CLI na mesma pasta final."
          TextWrapping="Wrap"
          Margin="0,8,0,0"/>

      <Button Content="Fechar"
              HorizontalAlignment="Right"
              Width="96"
              Click="CloseButton_Click"
              Margin="0,12,0,0"/>
    </StackPanel>
  </Border>
</Window>
