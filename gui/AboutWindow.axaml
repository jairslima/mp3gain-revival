<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MP3GainUI.AboutWindow"
        Title="Sobre o MP3Gain"
        Width="440" Height="360"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Border Padding="14">
    <DockPanel LastChildFill="True">
      <Button Content="OK"
              DockPanel.Dock="Bottom"
              HorizontalAlignment="Center"
              Width="84"
              Margin="0,12,0,0"
              Click="CloseButton_Click"/>

      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
          <Border Width="36" Height="36" BorderBrush="Gray" BorderThickness="1" Background="#E8E8E8">
            <TextBlock Text="♪" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22"/>
          </Border>

          <Grid Grid.Column="1" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="MP3Gain" FontWeight="Bold"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text='"Back End" (mp3gain.exe)' FontWeight="Bold"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Name="TxtFrontendVersion"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Name="TxtBackendVersion"/>
          </Grid>
        </Grid>

        <TextBlock Text="Executa a análise ReplayGain de arquivos MP3." TextWrapping="Wrap"/>
        <TextBlock Text="Para mais informações sobre o sistema ReplayGain, vá para http://replaygain.hydrogenaudio.org" TextWrapping="Wrap"/>
        <TextBlock Text="Última versão do MP3Gain Revival em https://github.com/jairslima/mp3gain-revival" TextWrapping="Wrap"/>
        <TextBlock Name="TxtReference" TextWrapping="Wrap"/>
        <TextBlock Text="Licença: LGPL 2.1 ou posterior." TextWrapping="Wrap"/>
      </StackPanel>
    </DockPanel>
  </Border>
</Window>
